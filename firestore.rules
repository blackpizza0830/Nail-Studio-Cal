rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function incoming() { return request.resource.data; }

    // Services — public read, server-side write via Admin SDK (bypasses rules)
    match /services/{serviceId} {
      allow read: if true;
      allow write: if false;
    }

    // Gallery — public read, server-side write via Admin SDK
    match /gallery/{itemId} {
      allow read: if true;
      allow write: if false;
    }

    // Customers — public self-serve create (CRM); read/update/delete for signed-in admin only.
    // Webhook/cron writes use Admin SDK (bypass rules).
    match /customers/{customerId} {
      allow read: if request.auth != null;
      allow create: if request.resource.data.email is string &&
                       request.resource.data.email.size() > 0;
      allow update, delete: if request.auth != null;
    }

    // Bookings — public create/read, update for cancellations
    function isValidBooking(data) {
      return data.serviceId is string &&
             data.serviceName is string &&
             data.date is string && data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$') &&
             data.time is string &&
             data.customerName is string &&
             data.customerEmail is string &&
             data.status in ['confirmed', 'cancelled'];
    }
    match /bookings/{bookingId} {
      allow create: if isValidBooking(incoming()) && incoming().status == 'confirmed';
      allow read: if true;
      allow update: if true;
    }
  }
}
