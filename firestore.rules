rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Services — public read, server-side write via Admin SDK (bypasses rules)
    match /services/{serviceId} {
      allow read: if true;
      allow write: if false;
    }

    // Gallery — public read, server-side write via Admin SDK
    match /gallery/{itemId} {
      allow read: if true;
      allow write: if false;
    }

    // Customers — server-side read/write via Admin SDK; client-side upsert allowed
    function isValidCustomer(data) {
      return data.name is string && data.name.size() > 0 &&
             data.email is string && data.email.size() > 5;
    }
    match /customers/{customerId} {
      allow read: if false;
      allow create: if isValidCustomer(incoming());
      allow update: if isValidCustomer(incoming());
    }

    // Bookings — public create/read, update for cancellations
    function isValidBooking(data) {
      return data.serviceId is string &&
             data.serviceName is string &&
             data.date is string && data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$') &&
             data.time is string &&
             data.customerName is string &&
             data.customerEmail is string &&
             data.status in ['confirmed', 'cancelled'];
    }
    match /bookings/{bookingId} {
      allow create: if isValidBooking(incoming()) && incoming().status == 'confirmed';
      allow read: if true;
      allow update: if true;
    }

    // Blocked times — public read, signed-in write
    match /blocked_times/{blockId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
